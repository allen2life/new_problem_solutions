{% extends "layout.njk" %}

{% block title %}{{ title }}{% endblock %}

{% block content %}
<div class="mb-4">
  <h1 class="h3">API 文档</h1>
  <p class="text-muted mb-0">用于 AI 调用和程序化检索的 RESTful 接口。</p>
</div>

<div class="card mb-4">
  <div class="card-body">
    <h2 class="h5">基础地址</h2>
    <code>{{ baseUrl }}</code>
  </div>
</div>

<div class="row g-3">
  {% for item in endpoints %}
  <div class="col-12">
    <div class="card">
      <div class="card-body">
        <div class="d-flex align-items-center gap-2 mb-2">
          <span class="badge bg-success">{{ item.method }}</span>
          <code>{{ item.path }}</code>
        </div>
        <p class="mb-2">{{ item.desc }}</p>
        <p class="mb-1"><strong>Query:</strong> <code>{{ item.query }}</code></p>
        <p class="mb-0"><strong>Example:</strong> <a class="problem-link" href="{{ item.example }}" target="_blank">{{ item.example }}</a></p>
      </div>
    </div>
  </div>
  {% endfor %}
</div>
{% endblock %}
