extends layout.pug

block title
  | #{problem.title} - 题目列表

mixin relationGroup(title, items)
  if items && items.length
    .problem-relation-group
      .problem-relation-heading #{title}
      .problem-relation-list
        each item in items
          a.problem-relation-item(class=item.missing ? 'is-missing' : '', href=item.url)
            span.problem-relation-code #{item.oj} #{item.problem_id}
            if item.title
              span.problem-relation-name #{item.title}
            if item.reason
              span.problem-relation-reason #{item.reason}

mixin recommendGroup(title, items)
  if items && items.length
    .problem-relation-group
      .problem-relation-heading #{title}
      .problem-relation-list
        each item in items
          - const relation = ['similar', 'easier', 'harder', 'practice'].includes(item.relation) ? item.relation : 'unknown'
          - const relationClass = `is-recommend-${relation}`
          if item.url
            a.problem-relation-item.problem-recommend-item.is-external(class=relationClass, href=item.url, target="_blank", rel="noopener noreferrer")
              span.problem-relation-code #{item.oj} #{item.problem_id}
              span.problem-recommend-relation(class=relationClass) #{item.relation || 'unknown'}
              if item.title
                span.problem-relation-name #{item.title}
              if item.reason
                span.problem-relation-reason #{item.reason}
          else
            .problem-relation-item.problem-recommend-item.is-external(class=relationClass)
              span.problem-relation-code #{item.oj} #{item.problem_id}
              span.problem-recommend-relation(class=relationClass) #{item.relation || 'unknown'}
              if item.title
                span.problem-relation-name #{item.title}
              if item.reason
                span.problem-relation-reason #{item.reason}

mixin difficultyBadge(difficulty)
  - const value = difficulty || ''
  - const difficultyMap = {'入门': 'entry', '普及-': 'basic', '普及/提高-': 'intermediate-minus', '普及+/提高': 'intermediate', '提高+/省选-': 'advanced-minus', '省选/NOI-': 'advanced', 'NOI/NOI+/CTSC': 'elite', '未知': 'unknown'}
  - const difficultyClass = `difficulty-${difficultyMap[value] || 'unknown'}`
  span.problem-difficulty-badge(class=difficultyClass) #{value || '未知'}

mixin lucideIcon(icon)
  svg.problem-toolbar-icon(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", width="20", height="20", fill="none", stroke="currentColor", stroke-width="2", stroke-linecap="round", stroke-linejoin="round", aria-hidden="true", focusable="false")
    case icon
      when 'zoom-in'
        // Iconify: lucide:zoom-in
        circle(cx="11", cy="11", r="8")
        path(d="m21 21-4.35-4.35")
        path(d="M11 8v6")
        path(d="M8 11h6")
      when 'zoom-out'
        // Iconify: lucide:zoom-out
        circle(cx="11", cy="11", r="8")
        path(d="m21 21-4.35-4.35")
        path(d="M8 11h6")
      when 'reset'
        // Iconify: lucide:rotate-ccw
        path(d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8")
        path(d="M3 3v5h5")
      when 'home'
        // Iconify: lucide:house
        path(d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8")
        path(d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z")
      when 'arrow-up'
        // Iconify: lucide:arrow-up
        path(d="m5 12 7-7 7 7")
        path(d="M12 19V5")

block content
  .problem-page
    nav.problem-floating-toolbar(aria-label="题解工具")
      button.problem-toolbar-button(type="button", data-problem-font="increase", title="字体增大", aria-label="字体增大")
        +lucideIcon('zoom-in')
      button.problem-toolbar-button(type="button", data-problem-font="decrease", title="字体缩小", aria-label="字体缩小")
        +lucideIcon('zoom-out')
      button.problem-toolbar-button(type="button", data-problem-font="reset", title="字体重置", aria-label="字体重置")
        +lucideIcon('reset')
      a.problem-toolbar-button(href="/", title="返回首页", aria-label="返回首页")
        +lucideIcon('home')
      button.problem-toolbar-button(type="button", data-scroll-top, title="返回顶部", aria-label="返回顶部")
        +lucideIcon('arrow-up')

    nav(aria-label="breadcrumb")
      ol.breadcrumb
        li.breadcrumb-item
          a(href="/") 首页
        li.breadcrumb-item
          a(href=`/?oj=${problem.oj}`) #{problem.oj}
        li.breadcrumb-item.active(aria-current="page") #{problem.problem_id}

    .card.mb-4.problem-summary-card
      .card-header
        .d-flex.justify-content-between.align-items-center
          h2.mb-0 #{problem.title}
          .d-flex.gap-2.problem-page-actions
            if githubUrl
              a.btn.btn-outline-dark.btn-sm(href=githubUrl, target="_blank", rel="noopener noreferrer") GitHub
            if problem.source
              a.btn.btn-outline-info.btn-sm(href=problem.source, target="_blank", rel="noopener noreferrer") 跳转原题
            if hasStatement
              button.btn.btn-outline-success.btn-sm(type="button", data-bs-toggle="modal", data-bs-target="#problemStatementModal") 显示题目
            else
              button.btn.btn-outline-secondary.btn-sm(type="button", disabled) 无题目
            button.btn.btn-outline-primary.btn-sm(type="button", data-problem-print) 打印
            a.btn.btn-outline-primary.btn-sm(href=`/relations?oj=${encodeURIComponent(problem.oj)}&pid=${encodeURIComponent(problem.problem_id)}`) 关系图
            a.btn.btn-outline-secondary.btn-sm(href="/") 返回列表
      .card-body
        if problem.description
          p.problem-description.mb-3 #{problem.description}
        .row.mb-3
          .col-md-6
            p
              strong OJ:
              |  #{problem.oj}
            p
              strong 题目 ID:
              |  #{problem.problem_id}
            p
              strong 难度:
              |
              +difficultyBadge(problem.difficulty)
          .col-md-6
            if problem.tags
              p
                strong 标签:
                |
                each tag in problem.tags
                  span.badge.bg-secondary.me-1 #{tag}
            if problem.date
              p
                strong 日期:
                |  #{problem.date}
        if (relations && relations.hasAny) || (recommendations && recommendations.length)
          .problem-relations
            +relationGroup('前置题目', relations ? relations.predecessors : [])
            +relationGroup('后置题目', relations ? relations.successors : [])
            +relationGroup('相似题目', relations ? relations.common : [])
            +recommendGroup('推荐练习', recommendations)

    .card.problem-content-card
      .card-body
        .markdown-body(data-problem-readable)
          != content

    if hasStatement
      #problemStatementModal.modal.fade.problem-statement-modal(tabindex="-1", aria-labelledby="problemStatementModalLabel", aria-hidden="true")
        .modal-dialog.modal-xl.modal-dialog-scrollable
          .modal-content
            .modal-header
              h2#problemStatementModalLabel.modal-title.fs-5 #{problem.oj} #{problem.problem_id} - 题目
              button.btn-close(type="button", data-bs-dismiss="modal", aria-label="关闭")
            .modal-body
              .markdown-body.problem-statement-body
                != statementHtml

block scripts
  script(src="/vendor/viz-global.js")
  script(src="https://cdn.jsdelivr.net/npm/mermaid@11/dist/mermaid.min.js")
  script(src="/javascripts/problem-toolbar.js")
  script(src="/javascripts/problem-graphviz.js")
  script(src="/javascripts/problem-mermaid.js")
