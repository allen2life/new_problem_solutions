extends layout.pug

block title
  | #{problem.title} - 题目列表

mixin relationGroup(title, items)
  if items && items.length
    .problem-relation-group
      .problem-relation-heading #{title}
      .problem-relation-list
        each item in items
          a.problem-relation-item(class=item.missing ? 'is-missing' : '', href=item.url)
            span.problem-relation-code #{item.oj} #{item.problem_id}
            if item.title
              span.problem-relation-name #{item.title}
            if item.reason
              span.problem-relation-reason #{item.reason}

mixin lucideIcon(icon)
  svg.problem-toolbar-icon(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", width="20", height="20", fill="none", stroke="currentColor", stroke-width="2", stroke-linecap="round", stroke-linejoin="round", aria-hidden="true", focusable="false")
    case icon
      when 'zoom-in'
        // Iconify: lucide:zoom-in
        circle(cx="11", cy="11", r="8")
        path(d="m21 21-4.35-4.35")
        path(d="M11 8v6")
        path(d="M8 11h6")
      when 'zoom-out'
        // Iconify: lucide:zoom-out
        circle(cx="11", cy="11", r="8")
        path(d="m21 21-4.35-4.35")
        path(d="M8 11h6")
      when 'reset'
        // Iconify: lucide:rotate-ccw
        path(d="M3 12a9 9 0 1 0 9-9 9.75 9.75 0 0 0-6.74 2.74L3 8")
        path(d="M3 3v5h5")
      when 'home'
        // Iconify: lucide:house
        path(d="M15 21v-8a1 1 0 0 0-1-1h-4a1 1 0 0 0-1 1v8")
        path(d="M3 10a2 2 0 0 1 .709-1.528l7-5.999a2 2 0 0 1 2.582 0l7 5.999A2 2 0 0 1 21 10v9a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z")
      when 'arrow-up'
        // Iconify: lucide:arrow-up
        path(d="m5 12 7-7 7 7")
        path(d="M12 19V5")

block content
  nav.problem-floating-toolbar(aria-label="题解工具")
    button.problem-toolbar-button(type="button", data-problem-font="increase", title="字体增大", aria-label="字体增大")
      +lucideIcon('zoom-in')
    button.problem-toolbar-button(type="button", data-problem-font="decrease", title="字体缩小", aria-label="字体缩小")
      +lucideIcon('zoom-out')
    button.problem-toolbar-button(type="button", data-problem-font="reset", title="字体重置", aria-label="字体重置")
      +lucideIcon('reset')
    a.problem-toolbar-button(href="/", title="返回首页", aria-label="返回首页")
      +lucideIcon('home')
    button.problem-toolbar-button(type="button", data-scroll-top, title="返回顶部", aria-label="返回顶部")
      +lucideIcon('arrow-up')

  nav(aria-label="breadcrumb")
    ol.breadcrumb
      li.breadcrumb-item
        a(href="/") 首页
      li.breadcrumb-item
        a(href=`/?oj=${problem.oj}`) #{problem.oj}
      li.breadcrumb-item.active(aria-current="page") #{problem.problem_id}

  .card.mb-4
    .card-header
      .d-flex.justify-content-between.align-items-center
        h2.mb-0 #{problem.title}
        .d-flex.gap-2
          if githubUrl
            a.btn.btn-outline-dark.btn-sm(href=githubUrl, target="_blank", rel="noopener noreferrer") GitHub
          a.btn.btn-outline-primary.btn-sm(href=`/relations?oj=${encodeURIComponent(problem.oj)}&pid=${encodeURIComponent(problem.problem_id)}`) 关系图
          a.btn.btn-outline-secondary.btn-sm(href="/") 返回列表
    .card-body
      .row.mb-3
        .col-md-6
          p
            strong OJ:
            |  #{problem.oj}
          p
            strong 题目 ID:
            |  #{problem.problem_id}
        .col-md-6
          if problem.tags
            p
              strong 标签:
              | 
              each tag in problem.tags
                span.badge.bg-secondary.me-1 #{tag}
          if problem.date
            p
              strong 日期:
              |  #{problem.date}
      if relations && relations.hasAny
        .problem-relations
          +relationGroup('前置题目', relations.predecessors)
          +relationGroup('后置题目', relations.successors)
          +relationGroup('相似题目', relations.common)

  .card.problem-content-card
    .card-body
      .markdown-body(data-problem-readable)
        != content

block scripts
  script(src="/javascripts/problem-toolbar.js")
