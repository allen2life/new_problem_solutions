doctype html
html(lang="zh-CN")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(name="theme-color", content="#1f2937")
    title
      block title
        | Problems Solution
    link(rel="icon", href="/favicon.svg", type="image/svg+xml")
    link(rel="icon", href="/favicon.ico", sizes="any")
    link(rel="apple-touch-icon", href="/apple-touch-icon.png")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    link(href="https://cdn.jsdelivr.net/npm/katex@0.17.0/dist/katex.min.css", rel="stylesheet")
    link(href="https://cdnjs.cloudflare.com/ajax/libs/prism/9000.0.1/themes/prism-tomorrow.min.css", rel="stylesheet")
    link(href="/stylesheets/style.css", rel="stylesheet")
    link(href="/stylesheets/problem-link.css", rel="stylesheet")
    script.
      (function () {
        try {
          var mode = localStorage.getItem('rbook.theme') || 'auto';
          var theme = mode === 'dark' || (mode === 'auto' && window.matchMedia('(prefers-color-scheme: dark)').matches) ? 'dark' : 'light';
          document.documentElement.setAttribute('data-bs-theme', theme);
          document.documentElement.dataset.themeMode = mode;
        } catch (error) {
          document.documentElement.setAttribute('data-bs-theme', 'light');
          document.documentElement.dataset.themeMode = 'auto';
        }
      }());
  body
    nav.navbar.navbar-expand-lg.navbar-dark.bg-dark
      .container
        a.navbar-brand(href="/") 题目列表
        button.navbar-toggler(type="button", data-bs-toggle="collapse", data-bs-target="#navbarNav")
          span.navbar-toggler-icon
        #navbarNav.collapse.navbar-collapse
          ul.navbar-nav.me-auto
            li.nav-item
              a.nav-link(href="/") 首页
            li.nav-item
              a.nav-link(href="/relations") 关系图
            li.nav-item
              a.nav-link(href="/api") API
          .navbar-theme-switcher(role="radiogroup", aria-label="主题切换")
            input#themeAuto.btn-check(type="radio", name="theme-mode", value="auto", data-theme-mode, autocomplete="off")
            label.btn.btn-outline-light.btn-sm(for="themeAuto") 系统
            input#themeLight.btn-check(type="radio", name="theme-mode", value="light", data-theme-mode, autocomplete="off")
            label.btn.btn-outline-light.btn-sm(for="themeLight") 浅色
            input#themeDark.btn-check(type="radio", name="theme-mode", value="dark", data-theme-mode, autocomplete="off")
            label.btn.btn-outline-light.btn-sm(for="themeDark") 深色

    main.container-xxl.my-4
      block content

    footer.text-center.py-3.mt-4.border-top
      p.text-muted.mb-0 © 2026 题目列表

    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js")
    script(src="/javascripts/theme-switcher.js")
    script(src="/javascripts/code-copy.js")
    block scripts
