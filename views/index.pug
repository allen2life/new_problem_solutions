extends layout.pug

block title
  | 题目列表 - 题目列表

mixin difficultyBadge(difficulty)
  - const value = difficulty || ''
  - const difficultyMap = {'入门': 'entry', '普及-': 'basic', '普及/提高-': 'intermediate-minus', '普及+/提高': 'intermediate', '提高+/省选-': 'advanced-minus', '省选/NOI-': 'advanced', 'NOI/NOI+/CTSC': 'elite', '未知': 'unknown'}
  - const difficultyClass = `difficulty-${difficultyMap[value] || 'unknown'}`
  span.problem-difficulty-badge(class=difficultyClass) #{value || '未知'}

block content
  .index-shell
    .index-head
      .index-head__title
        h1.h3.mb-1 题目列表
        p.text-muted.mb-0 可按标题、OJ、标签快速筛选题目解析。
      .index-head__meta
        span.index-count 共 #{pagination.total} 题

    .index-toolbar
      form.index-search(action="/", method="GET")
        input.form-control(type="search", name="q", placeholder="搜索题目标题或 ID", value=query)
        if currentOJ
          input(type="hidden", name="oj", value=currentOJ)
        if currentTag
          input(type="hidden", name="tag", value=currentTag)
        button.btn.btn-primary(type="submit") 搜索
      .index-filters
        select.form-select(name="oj", onchange="filterByOJ(this.value)")
          option(value="") 全部 OJ
          each oj in ojs
            option(value=oj, selected=oj === currentOJ) #{oj}
        select.form-select(name="tag", onchange="filterByTag(this.value)")
          option(value="") 全部标签
          each tag in tags
            option(value=tag, selected=tag === currentTag) #{tag}

    .table-responsive.index-table-wrap
      table.table.table-hover.align-middle.index-table
        thead
          tr
            th(scope="col") 标题
            th(scope="col") OJ
            th(scope="col") 题号
            th(scope="col") 标签
            th(scope="col") 难度
            th(scope="col") 最后更新
            th(scope="col") 原题
        tbody
          each problem in problems
            tr
              td.index-table__title
                a.index-table__title-link(href=problem.url) #{problem.title}
                if problem.description
                  .index-table__description #{problem.description}
              td
                span.index-pill #{problem.oj}
              td
                code.index-code #{problem.problem_id}
              td
                if problem.tags && problem.tags.length
                  .index-tags
                    each tag in problem.tags
                      span.badge.text-bg-light.index-tag #{tag}
                else
                  span.text-muted -
              td
                if problem.difficulty
                  +difficultyBadge(problem.difficulty)
                else
                  span.text-muted -
              td
                if problem.date
                  span.text-nowrap #{problem.date}
                else
                  span.text-muted -
              td
                if problem.source
                  a.btn.btn-sm.btn-outline-secondary(href=problem.source, target="_blank", rel="noopener noreferrer") 打开
                else
                  span.text-muted -

  if pagination
    nav.index-pagination(aria-label="Page navigation")
      ul.pagination.justify-content-center
        if pagination.page > 1
          li.page-item
            a.page-link(href=pageUrl(pagination.page - 1)) 上一页

        - for (let page = 1; page <= pagination.totalPages; page += 1)
          if page === pagination.page
            li.page-item.active
              a.page-link(href="#") #{page}
          else
            li.page-item
              a.page-link(href=pageUrl(page)) #{page}

        if pagination.page < pagination.totalPages
          li.page-item
            a.page-link(href=pageUrl(pagination.page + 1)) 下一页

block scripts
  script.
    function filterByOJ(oj) {
      const url = new URL(window.location);
      if (oj) {
        url.searchParams.set('oj', oj);
      } else {
        url.searchParams.delete('oj');
      }
      window.location = url;
    }

    function filterByTag(tag) {
      const url = new URL(window.location);
      if (tag) {
        url.searchParams.set('tag', tag);
      } else {
        url.searchParams.delete('tag');
      }
      window.location = url;
    }
