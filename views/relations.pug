doctype html
html(lang="zh-CN")
  head
    meta(charset="UTF-8")
    meta(name="viewport", content="width=device-width, initial-scale=1.0")
    meta(name="theme-color", content="#1f2937")
    title #{title} - 题目列表
    link(rel="icon", href="/favicon.svg", type="image/svg+xml")
    link(rel="icon", href="/favicon.ico", sizes="any")
    link(rel="apple-touch-icon", href="/apple-touch-icon.png")
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css", rel="stylesheet")
    link(href="/stylesheets/style.css", rel="stylesheet")
    link(href="/stylesheets/problem-link.css", rel="stylesheet")
  body.relations-body
    .relations-page
      .relations-settings
        button.relations-settings-toggle(type="button", data-relation-settings-toggle, title="设置", aria-label="设置", aria-expanded="false")
          svg(xmlns="http://www.w3.org/2000/svg", viewBox="0 0 24 24", width="22", height="22", fill="none", stroke="currentColor", stroke-width="2", stroke-linecap="round", stroke-linejoin="round", aria-hidden="true")
            path(d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.38a2 2 0 0 0-.73-2.73l-.15-.09a2 2 0 0 1-1-1.74v-.51a2 2 0 0 1 1-1.72l.15-.1a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z")
            circle(cx="12", cy="12", r="3")
        .relations-toolbar(data-relation-settings-panel, aria-label="关系图设置")
          .relations-toolbar-title
            strong 题目关系图
            span(data-relations-summary) 正在加载...
          .relations-toolbar-row
            label.relations-search
              span.visually-hidden 搜索题目
              input.form-control.form-control-sm(type="search", data-relation-search, placeholder="搜索 OJ / 题号 / 标题 / tag")
            select.form-select.form-select-sm(data-relation-layout, aria-label="布局")
              option(value="cose") 力导向
              option(value="breadthfirst") 层级
              option(value="circle") 环形
          .relations-toolbar-row.relations-toggles
            label.relations-toggle
              input.form-check-input(type="checkbox", data-edge-toggle="pre", checked)
              span pre
            label.relations-toggle
              input.form-check-input(type="checkbox", data-edge-toggle="common", checked)
              span common
            label.relations-toggle
              input.form-check-input(type="checkbox", data-isolated-toggle)
              span 孤立题目
            label.relations-toggle
              input.form-check-input(type="checkbox", data-legend-toggle, checked)
              span 主要标签
          .relations-slider-group
            label.relations-slider
              span 滚轮缩放速度
              output(data-layout-output="wheelSensitivity")
              input.form-range(type="range", data-layout-param="wheelSensitivity", min="0.1", max="1.5", step="0.1")
            label.relations-slider
              span 边长
              output(data-layout-output="idealEdgeLength")
              input.form-range(type="range", data-layout-param="idealEdgeLength", min="60", max="260", step="5")
            label.relations-slider
              span 节点斥力
              output(data-layout-output="nodeRepulsion")
              input.form-range(type="range", data-layout-param="nodeRepulsion", min="2000", max="20000", step="500")
            label.relations-slider
              span 组件间距
              output(data-layout-output="componentSpacing")
              input.form-range(type="range", data-layout-param="componentSpacing", min="40", max="240", step="10")
            label.relations-slider
              span 重力
              output(data-layout-output="gravity")
              input.form-range(type="range", data-layout-param="gravity", min="0.02", max="0.5", step="0.02")
            label.relations-slider
              span 层级间距
              output(data-layout-output="spacingFactor")
              input.form-range(type="range", data-layout-param="spacingFactor", min="0.5", max="1.5", step="0.05")
          .relations-toolbar-actions
            button.btn.btn-sm.btn-primary(type="button", data-layout-apply) 应用布局
            button.btn.btn-sm.btn-outline-secondary(type="button", data-relation-fit) 适应视图
            a.btn.btn-sm.btn-outline-secondary(href="/") 首页

      #relations-graph.relations-graph(role="application", aria-label="题目关系图")

      aside.relations-panel(data-relation-panel)
        .relations-panel-empty 选择一个题目节点查看关系。

      .relations-legend(data-relations-legend)

    script(src="https://cdn.jsdelivr.net/npm/cytoscape@3/dist/cytoscape.min.js")
    script(src="/javascripts/problem-relations-graph.js")
