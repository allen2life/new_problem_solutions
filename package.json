{
  "name": "rbook",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "bin": {
    "rbook": "./bin/rbook.js"
  },
  "scripts": {
    "prestart": "npm run generate:problems",
    "start": "node ./bin/www",
    "preview": "node ./bin/rbook.js preview",
    "test": "node --test tests/*.test.js",
    "generate:problems": "node ./scripts/generate-problems-json.js",
    "build": "npm run generate:problems && npm run build:relations",
    "build:relations": "vite build --config relations-graph/vite.config.ts"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/formbody": "^8.0.2",
    "@fastify/static": "^9.1.3",
    "@fastify/view": "^11.1.1",
    "@xyflow/react": "^12.11.0",
    "cheerio": "^1.0.0-rc.12",
    "d3-force": "^3.0.0",
    "debug": "~2.6.9",
    "ejs": "^3.1.10",
    "elkjs": "^0.11.1",
    "fastify": "^5.8.5",
    "glob": "^13.0.6",
    "gray-matter": "^4.0.3",
    "js-yaml": "^4.2.0",
    "katex": "^0.17.0",
    "markdown-it": "^14.2.0",
    "markdown-it-abbr": "^2.0.0",
    "markdown-it-anchor": "^9.2.0",
    "markdown-it-codetabs": "^1.2.0",
    "markdown-it-container": "^4.0.0",
    "markdown-it-emoji": "^3.0.0",
    "markdown-it-iframe": "^1.0.0",
    "markdown-it-image-figures": "^2.1.1",
    "markdown-it-imsize": "^2.0.1",
    "markdown-it-inline-comments": "^1.0.1",
    "markdown-it-ins-del": "^0.1.1",
    "markdown-it-mark": "^4.0.0",
    "markdown-it-sub": "^2.0.0",
    "markdown-it-sup": "^2.0.0",
    "markdown-it-task-checkbox": "^1.0.6",
    "markdown-it-texmath": "^1.0.0",
    "markdown-it-toc-done-right": "^4.2.0",
    "nunjucks": "^3.2.4",
    "prismjs": "^1.30.0",
    "pug": "^3.0.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "twemoji": "^14.0.2",
    "uslug": "^1.0.4"
  },
  "devDependencies": {
    "@types/d3-force": "^3.0.10",
